+                description="Show an unstaged or staged local git diff without external diff commands.",
+                func=self.git_diff,
+                title="Git Diff",
+                default_on=True,
+                icon_name="vcs-diff-symbolic",
+                tools_group=group,
+            ),
+            Tool(
+                name="git_log",
+                description="Show a bounded read-only local git commit log.",
+                func=self.git_log,
+                title="Git Log",
+                default_on=True,
+                icon_name="vcs-normal-symbolic",
+                tools_group=group,
+            ),
+            Tool(
+                name="list_forge_issues",
+                description=(
+                    "List issues from GitHub, GitLab, or a Gitea-compatible server. "
+                    "Uses environment tokens only and never mutates the remote."
+                ),
+                func=self.list_issues,
+                title="List Forge Issues",
+                default_on=True,
+                icon_name="dialog-information-symbolic",
+                tools_group=group,
+            ),
+        ]

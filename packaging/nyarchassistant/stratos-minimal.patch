+import json
+import os
+import re
+import subprocess
+from urllib.parse import quote, urlencode, urlsplit, urlunsplit
+from urllib.request import Request, urlopen
+
+from ..extensions import NewelleExtension
+from ..tools import Tool, ToolResult
+
+
+MAX_GIT_OUTPUT_BYTES = 256 * 1024
+MAX_HTTP_RESPONSE_BYTES = 1024 * 1024
+GIT_TIMEOUT_SECONDS = 15
+HTTP_TIMEOUT_SECONDS = 10
+MAX_ISSUES = 100
+SUPPORTED_PROVIDERS = ("github", "gitlab", "gitea")
+_REPO_SEGMENT = re.compile(r"^[A-Za-z0-9_.-]+$")
+_TOKEN_SETTINGS = {
+    "github": ("GITHUB_TOKEN", "GITHUB_BASE_URL"),
+    "gitlab": ("GITLAB_TOKEN", "GITLAB_BASE_URL"),
+    "gitea": ("GIT_FORGE_TOKEN", "GIT_FORGE_BASE_URL"),
+}
+_DEFAULT_TRUSTED_BASE_URLS = {
+    "github": "https://api.github.com",
+    "gitlab": "https://gitlab.com",
+}
+
+
+def validate_provider(provider: str) -> str:
+    if not isinstance(provider, str) or provider.lower() not in SUPPORTED_PROVIDERS:
+        raise ValueError(
+            f"provider must be one of: {', '.join(SUPPORTED_PROVIDERS)}"
+        )
+    return provider.lower()
+
+
+def validate_repo(repo: str) -> str:
+    if not isinstance(repo, str) or len(repo) > 300:
+        raise ValueError("repo must be a forge repository path")
+    segments = repo.strip("/").split("/")
+    if len(segments) < 2 or any(
+        segment in ("", ".", "..") or not _REPO_SEGMENT.fullmatch(segment)
+        for segment in segments
+    ):
+        raise ValueError("repo must contain valid owner/name path segments")
+    return "/".join(segments)
+
+
+def normalize_origin(url: str) -> tuple[str, str, int]:
+    """Return a canonical scheme/host/port origin for a credential-free URL."""
+    if not isinstance(url, str) or not url.strip():
+        raise ValueError("URL must be a non-empty string")
+    parsed = urlsplit(url.strip())
+    if (
+        parsed.scheme.lower() not in ("http", "https")
+        or not parsed.hostname
+        or parsed.username is not None
+        or parsed.password is not None
+        or any(character.isspace() or character == "\\" for character in parsed.netloc)
+    ):
+        raise ValueError("URL must have a safe http(s) origin without credentials")
+    try:
+        port = parsed.port
+        hostname = parsed.hostname.rstrip(".").encode("idna").decode("ascii").lower()
+    except (UnicodeError, ValueError) as exc:
+        raise ValueError("URL contains an invalid host or port") from exc
+    if not hostname:
+        raise ValueError("URL contains an invalid host")
+    if port is None:
+        port = 443 if parsed.scheme.lower() == "https" else 80
+    return parsed.scheme.lower(), hostname, port
+
+
+def validate_base_url(provider: str, base_url: str | None = None) -> str:
+    provider = validate_provider(provider)
+    defaults = {
+        "github": "https://api.github.com",
+        "gitlab": "https://gitlab.com",
+    }
+    value = (base_url or defaults.get(provider, "")).strip().rstrip("/")
+    if not value:
+        raise ValueError("base_url is required for a Gitea-compatible server")
+    parsed = urlsplit(value)
+    if (
+        parsed.query
+        or parsed.fragment
+    ):
+        raise ValueError(
+            "base_url must be an http(s) URL without credentials, query, or fragment"
+        )
+    normalize_origin(value)
+    return urlunsplit((parsed.scheme, parsed.netloc, parsed.path.rstrip("/"), "", ""))
+
+
+def trusted_origins(provider: str, environment=None) -> set[tuple[str, str, int]]:
+    """Return provider origins that may receive an environment token."""
+    provider = validate_provider(provider)
+    environment = os.environ if environment is None else environment
+    origins = set()
+    default_base_url = _DEFAULT_TRUSTED_BASE_URLS.get(provider)
+    if default_base_url:
+        origins.add(normalize_origin(default_base_url))
+    configured_base_url = environment.get(_TOKEN_SETTINGS[provider][1], "")
+    if configured_base_url:
+        try:
+            origins.add(normalize_origin(configured_base_url))
+        except ValueError:
+            # An invalid or credential-bearing trust URL never enables credentials.
+            pass
+    return origins
+
+
+def may_attach_token(provider: str, request_url: str, environment=None) -> bool:
+    """Whether request_url exactly matches a trusted provider origin."""
+    try:
+        return normalize_origin(request_url) in trusted_origins(provider, environment)
+    except ValueError:
+        return False
+
+
+def build_issues_url(
+    provider: str,
+    repo: str,
+    base_url: str | None = None,
+    state: str = "open",
+    limit: int = 20,
+) -> str:
+    provider = validate_provider(provider)
+    repo = validate_repo(repo)
+    base_url = validate_base_url(provider, base_url)
+    if state not in ("open", "closed", "all"):
+        raise ValueError("state must be open, closed, or all")
+    try:
+        limit = max(1, min(int(limit), MAX_ISSUES))
+    except (TypeError, ValueError) as exc:
+        raise ValueError("limit must be an integer") from exc
+
+    if provider == "github":
+        path = f"/repos/{quote(repo, safe='/')}/issues"
+        query = {"state": state, "per_page": limit}
+    elif provider == "gitlab":
+        api_base = base_url if base_url.endswith("/api/v4") else base_url + "/api/v4"
+        path = f"/projects/{quote(repo, safe='')}/issues"
+        query = {
+            "state": {"open": "opened", "closed": "closed", "all": "all"}[state],
+            "per_page": limit,
+        }
+        return api_base + path + "?" + urlencode(query)
+    else:
+        api_base = base_url if base_url.endswith("/api/v1") else base_url + "/api/v1"
+        path = f"/repos/{quote(repo, safe='/')}/issues"
+        query = {"state": state, "limit": limit}
+        return api_base + path + "?" + urlencode(query)
+    return base_url + path + "?" + urlencode(query)
+
+
+def parse_issues_response(provider: str, payload: bytes) -> list[dict]:
+    provider = validate_provider(provider)
+    try:
+        data = json.loads(payload.decode("utf-8"))
+    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
+        raise ValueError("forge returned invalid JSON") from exc
+    if not isinstance(data, list):
+        raise ValueError("forge returned an unexpected issue response")
+
+    issues = []
+    for item in data:
+        if not isinstance(item, dict):
+            continue
+        if provider == "github" and "pull_request" in item:
+            continue
+        number = item.get("iid") if provider == "gitlab" else item.get("number")
+        title = item.get("title")
+        if not isinstance(number, int) or not isinstance(title, str):
+            continue
+        issues.append(
+            {
+                "number": number,
+                "title": title,
+                "state": item.get("state", ""),
+                "url": item.get("web_url") if provider == "gitlab" else item.get("html_url", ""),
+                "comments": item.get("user_notes_count", 0)
+                if provider == "gitlab"
+                else item.get("comments", 0),
+            }
+        )
+    return issues
+
+
+class GitForgeIntegration(NewelleExtension):
+    """Read-only local Git and remote issue-listing tools."""
+
+    id = "git_forge"
+    name = "Git Forge"
+
+    @staticmethod
+    def _result(output: str) -> ToolResult:
+        result = ToolResult()
+        result.set_output(output)
+        return result
+
+    @staticmethod
+    def _validate_local_path(path: str) -> str:
+        if not isinstance(path, str) or not os.path.isabs(path):
+            raise ValueError("path must be absolute")
+        path = os.path.realpath(path)
+        if not os.path.isdir(path):
+            raise ValueError("path must be an existing directory")
+        return path
+
+    def _run_git(self, path: str, arguments: list[str]) -> ToolResult:
+        try:
+            path = self._validate_local_path(path)
+            completed = subprocess.run(
+                [
+                    "git",
+                    "--no-optional-locks",
+                    "-c",
+                    "core.fsmonitor=false",
+                    "-c",
+                    "diff.external=",
+                    "-C",
+                    path,
+                    *arguments,
+                ],
+                stdin=subprocess.DEVNULL,
+                stdout=subprocess.PIPE,
+                stderr=subprocess.PIPE,
+                timeout=GIT_TIMEOUT_SECONDS,
+                check=False,
+            )
+            raw = completed.stdout if completed.returncode == 0 else completed.stderr
+            truncated = len(raw) > MAX_GIT_OUTPUT_BYTES
+            text = raw[:MAX_GIT_OUTPUT_BYTES].decode("utf-8", errors="replace").rstrip()
+            if truncated:
+                text += f"\n\n[output truncated at {MAX_GIT_OUTPUT_BYTES} bytes]"
+            if completed.returncode != 0:
+                return self._result(
+                    f"Git command failed with exit code {completed.returncode}: {text}"
+                )
+            return self._result(text or "(no output)")
+        except subprocess.TimeoutExpired:
+            return self._result(
+                f"Git command timed out after {GIT_TIMEOUT_SECONDS} seconds"
+            )
+        except (OSError, ValueError) as exc:
+            return self._result(f"Git error: {exc}")
+
+    def git_status(self, path: str):
+        return self._run_git(path, ["status", "--short", "--branch"])
+
+    def git_diff(self, path: str, staged: bool = False):
+        arguments = ["diff", "--no-ext-diff", "--no-textconv", "--no-color"]
+        if staged:
+            arguments.append("--cached")
+        return self._run_git(path, arguments)
+
+    def git_log(self, path: str, limit: int = 20):
+        try:
+            limit = max(1, min(int(limit), 100))
+        except (TypeError, ValueError):
+            return self._result("Git error: limit must be an integer")
+        return self._run_git(
+            path,
+            ["log", f"--max-count={limit}", "--date=iso-strict", "--format=%h %ad %s"],
+        )
+
+    def list_issues(
+        self,
+        provider: str,
+        repo: str,
+        base_url: str = "",
+        state: str = "open",
+        limit: int = 20,
+    ):
+        token = None
+        try:
+            provider = validate_provider(provider)
+            configured_base_url = os.environ.get(_TOKEN_SETTINGS[provider][1], "")
+            effective_base_url = base_url or configured_base_url or None
+            url = build_issues_url(provider, repo, effective_base_url, state, limit)
+            token = os.environ.get(_TOKEN_SETTINGS[provider][0])
+            headers = {
+                "Accept": "application/json",
+                "User-Agent": "NyarchAssistant-GitForge/1",
+            }
+            request = Request(url, headers=headers, method="GET")
+            if token and may_attach_token(provider, url):
+                if provider == "gitlab":
+                    request.add_unredirected_header("PRIVATE-TOKEN", token)
+                elif provider == "gitea":
+                    request.add_unredirected_header("Authorization", f"token {token}")
+                else:
+                    request.add_unredirected_header("Authorization", f"Bearer {token}")
+            with urlopen(request, timeout=HTTP_TIMEOUT_SECONDS) as response:
+                payload = response.read(MAX_HTTP_RESPONSE_BYTES + 1)
+            if len(payload) > MAX_HTTP_RESPONSE_BYTES:
+                raise ValueError(
+                    f"forge response exceeds {MAX_HTTP_RESPONSE_BYTES} bytes"
+                )
+            issues = parse_issues_response(provider, payload)
+            return self._result(json.dumps(issues, indent=2))
+        except Exception as exc:
+            error = str(exc)
+            if token:
+                error = error.replace(token, "[REDACTED]")
+            return self._result(f"Forge error: {error}")
+
+    def get_tools(self) -> list:
+        group = "Git Forge (Read Only)"
+        return [
+            Tool(
+                name="git_status",
+                description="Show read-only local git status for an absolute repository path.",
+                func=self.git_status,
+                title="Git Status",
+                default_on=True,
+                icon_name="vcs-normal-symbolic",
+                tools_group=group,
+            ),
+            Tool(

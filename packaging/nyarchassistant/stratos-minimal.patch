@@ -0,0 +1,61 @@
+import unittest
+
+from src.utility.compact import resolve_window_layout
+from src.utility.lifecycle import LifecycleCleanupGuard
+
+
+class CompactLayoutTests(unittest.TestCase):
+    def test_compact_defaults_are_phone_sized(self):
+        layout = resolve_window_layout(True, 1400, 800, 420, 720, 132)
+
+        self.assertEqual((layout.width, layout.height), (420, 720))
+        self.assertEqual(layout.avatar_width, 132)
+        self.assertEqual(layout.chat_min_width, 288)
+        self.assertEqual(layout.lazy_load_batch_size, 5)
+
+    def test_compact_values_are_kept_usable(self):
+        layout = resolve_window_layout(True, 1400, 800, -1, 0, 999)
+
+        self.assertEqual((layout.width, layout.height), (420, 720))
+        self.assertEqual(layout.avatar_width, 210)
+        self.assertGreaterEqual(layout.chat_min_width, 240)
+        self.assertLess(layout.history_width, layout.width)
+        self.assertLess(layout.canvas_width, layout.width)
+
+    def test_normal_mode_preserves_existing_dimensions_and_layout(self):
+        layout = resolve_window_layout(False, 1250, 775, 420, 720, 132)
+
+        self.assertEqual((layout.width, layout.height), (1250, 775))
+        self.assertEqual(layout.chat_min_width, 450)
+        self.assertEqual(layout.history_width, 300)
+        self.assertEqual(layout.canvas_width, 420)
+        self.assertEqual(layout.avatar_width, 400)
+        self.assertEqual(layout.lazy_load_batch_size, 10)
+
+
+class LifecycleCleanupGuardTests(unittest.TestCase):
+    def test_cleanup_can_only_be_claimed_once_per_activation(self):
+        guard = LifecycleCleanupGuard()
+        handler = object()
+
+        guard.activate(handler)
+        self.assertTrue(guard.claim_cleanup(handler))
+        self.assertFalse(guard.claim_cleanup(handler))
+
+    def test_reactivated_handler_represents_a_new_lifecycle(self):
+        guard = LifecycleCleanupGuard()
+        handler = object()
+
+        guard.activate(handler)
+        self.assertTrue(guard.claim_cleanup(handler))
+        guard.activate(handler)
+        self.assertTrue(guard.claim_cleanup(handler))
+
+    def test_unloaded_or_unknown_handler_is_safe(self):
+        guard = LifecycleCleanupGuard()
+        self.assertFalse(guard.claim_cleanup(None))
+        self.assertFalse(guard.claim_cleanup(object()))
+
+
+if __name__ == "__main__":
+    unittest.main()

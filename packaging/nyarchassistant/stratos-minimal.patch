+++ b/src/handlers/llm/kimi_handler.py
@@ -0,0 +1,94 @@
+from gettext import gettext as _
+
+from .openai_handler import OpenAIHandler
+from ...handlers import ExtraSettings
+
+
+SWARM_SYSTEM_INSTRUCTION = (
+    "Swarm orchestration is enabled. For complex tasks, explicitly decompose the "
+    "work into independent subtasks and use available subagent tools to run "
+    "independent work in parallel when useful. Keep simple tasks direct, respect "
+    "all tool permissions, and synthesize the subagent results into one answer."
+)
+KIMI_K2_6_QUICKSTART_URL = (
+    "https://platform.moonshot.ai/docs/guide/kimi-k2-6-quickstart"
+)
+
+
+class KimiHandler(OpenAIHandler):
+    """Moonshot AI's OpenAI-compatible Kimi K2.6 handler."""
+
+    key = "kimi"
+    default_models = (("kimi-k2.6", "kimi-k2.6"),)
+    endpoint = "https://api.moonshot.ai/v1"
+
+    def __init__(self, settings, path):
+        super().__init__(settings, path)
+        self.set_setting("endpoint", self.endpoint)
+
+    def get_models(self, manual=False):
+        """Kimi K2.6 is intentionally exposed under its official model ID."""
+        self.models = self.default_models
+
+    def supports_vision(self) -> bool:
+        return True
+
+    def get_extra_settings(self) -> list:
+        settings = self.build_extra_settings(
+            "Moonshot Kimi",
+            True,
+            True,
+            False,
+            True,
+            False,
+            "https://www.moonshot.ai/privacy-policy",
+            KIMI_K2_6_QUICKSTART_URL,
+            supports_tool_calling=True,
+            has_tool_calling_option=True,
+        )
+        model_setting = ExtraSettings.ComboSetting(
+            "model",
+            _("Kimi Model"),
+            _("Official Moonshot model ID"),
+            self.default_models,
+            "kimi-k2.6",
+        )
+        model_setting["website"] = KIMI_K2_6_QUICKSTART_URL
+        settings.insert(
+            1,
+            model_setting,
+        )
+        settings += [
+            ExtraSettings.ToggleSetting(
+                "thinking",
+                _("Thinking Mode"),
+                _("Send Moonshot's native thinking enabled/disabled request body"),
+                True,
+            ),
+            ExtraSettings.ToggleSetting(
+                "swarm_mode",
+                _("Swarm Orchestration Prompt"),
+                _(
+                    "Encourage Kimi to decompose complex work and coordinate "
+                    "parallel subagents; this adds a system instruction and is "
+                    "not a Moonshot API parameter"
+                ),
+                False,
+            ),
+        ]
+        return settings
+
+    def get_thinking_params(self):
+        state = "enabled" if self.get_setting("thinking", False, True) else "disabled"
+        return {"thinking": {"type": state}}
+
+    def prepare_system_prompts(self, prompts: list[str] | None) -> list[str]:
+        prepared = list(prompts or [])
+        if self.get_setting("swarm_mode", False, False):
+            prepared.append(SWARM_SYSTEM_INSTRUCTION)
+        return prepared
+
+    def convert_history(self, history: list, prompts: list | None = None) -> list:
+        if prompts is None:
+            prompts = self.prompts
+        return super().convert_history(history, self.prepare_system_prompts(prompts))

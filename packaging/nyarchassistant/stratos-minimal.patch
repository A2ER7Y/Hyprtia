+    def test_llama_four_models_are_marked_extreme(self):
+        by_key = {model["key"]: model for model in get_recommended_ollama_models()}
+
+        for key in ("llama4:scout", "llama4:maverick"):
+            self.assertEqual(by_key[key]["hardware_tier"], "extreme")
+            self.assertIn("Extremely hardware-heavy", by_key[key]["description"])
+
+    def test_catalog_does_not_present_kimi_as_local(self):
+        keys = [model["key"].lower() for model in get_recommended_ollama_models()]
+        self.assertFalse(any("kimi" in key for key in keys))

+import json
+import sys
+import types
+import unittest
+from unittest.mock import patch
+
+from tests.gi_stubs import install
+
+install()
+
+from src.handlers.llm.kimi_handler import (
+    KIMI_K2_6_QUICKSTART_URL,
+    KimiHandler,
+    SWARM_SYSTEM_INSTRUCTION,
+)
+
+
+class FakeSettings:
+    def __init__(self):
+        self.values = {"llm-settings": "{}"}
+
+    def get_string(self, key):
+        return self.values.get(key, "{}")
+
+    def set_string(self, key, value):
+        self.values[key] = value
+
+
+class FakeCompletions:
+    last_kwargs = None
+
+    def create(self, **kwargs):
+        self.last_kwargs = kwargs
+        FakeCompletions.last_kwargs = kwargs
+        message = types.SimpleNamespace(content="ok", tool_calls=None)
+        return types.SimpleNamespace(
+            choices=[types.SimpleNamespace(message=message)]
+        )
+
+
+class FakeOpenAI:
+    last_init = None
+
+    def __init__(self, **kwargs):
+        FakeOpenAI.last_init = kwargs
+        self.chat = types.SimpleNamespace(completions=FakeCompletions())
+
+
+class KimiHandlerTests(unittest.TestCase):
+    def setUp(self):
+        self.settings = FakeSettings()
+        self.handler = KimiHandler(self.settings, "/tmp/cache")
+        self.handler.set_setting("native_tool_calling", False)
+        self.handler.set_setting("advanced_params", False)
+
+    def test_official_endpoint_model_and_thinking_body(self):
+        fake_openai = types.ModuleType("openai")
+        fake_openai.OpenAI = FakeOpenAI
+        fake_openai.NOT_GIVEN = object()
+
+        self.handler.set_setting("thinking", True)
+        self.handler.set_setting("swarm_mode", True)
+        with patch.dict(sys.modules, {"openai": fake_openai}):
+            output = self.handler.generate_text(
+                "hello",
+                history=[],
+                system_prompt=["base instruction"],
+            )
+
+        self.assertEqual(output, "ok")
+        self.assertEqual(
+            FakeOpenAI.last_init["base_url"],
+            "https://api.moonshot.ai/v1",
+        )
+        request = FakeCompletions.last_kwargs
+        self.assertEqual(request["model"], "kimi-k2.6")
+        self.assertEqual(
+            request["extra_body"],
+            {"thinking": {"type": "enabled"}},
+        )
+        self.assertIn("base instruction", request["messages"][0]["content"])
+        self.assertIn(SWARM_SYSTEM_INSTRUCTION, request["messages"][0]["content"])
+        self.assertNotIn("swarm_mode", request["extra_body"])
+
+    def test_disabled_thinking_and_swarm_prompt_are_explicit(self):

@@ -0,0 +1,56 @@
+import json
+import unittest
+
+from tests.gi_stubs import install
+
+install()
+
+from src.integrations.agent_tools import (
+    DEFAULT_SWARM_CONCURRENCY,
+    MAX_SWARM_CONCURRENCY,
+    MAX_SWARM_TASKS,
+    enforce_swarm_cap,
+    parse_swarm_tasks,
+)
+
+
+class SwarmHelperTests(unittest.TestCase):
+    def test_parses_json_and_preserves_order(self):
+        tasks = parse_swarm_tasks(
+            json.dumps(
+                [
+                    "first",
+                    {
+                        "task": "second",
+                        "tools": "read_file",
+                        "system_prompt": "be exact",
+                    },
+                ]
+            )
+        )
+
+        self.assertEqual([item["task"] for item in tasks], ["first", "second"])
+        self.assertEqual(tasks[1]["tools"], "read_file")
+        self.assertEqual(tasks[1]["system_prompt"], "be exact")
+        self.assertEqual(tasks[0]["skills"], "")
+
+    def test_rejects_invalid_and_oversized_task_lists(self):
+        for value in ("not json", {}, [], [""], [1]):
+            with self.subTest(value=value):
+                with self.assertRaises(ValueError):
+                    parse_swarm_tasks(value)
+        with self.assertRaises(ValueError):
+            parse_swarm_tasks(["task"] * (MAX_SWARM_TASKS + 1))
+
+    def test_concurrency_is_bounded_by_eight(self):
+        self.assertEqual(enforce_swarm_cap(), DEFAULT_SWARM_CONCURRENCY)
+        self.assertEqual(enforce_swarm_cap(999), MAX_SWARM_CONCURRENCY)
+        self.assertEqual(enforce_swarm_cap(7, hard_cap=4), 4)
+        with self.assertRaises(ValueError):
+            enforce_swarm_cap(0)
+        with self.assertRaises(ValueError):
+            enforce_swarm_cap("many")
+
+
+if __name__ == "__main__":
+    unittest.main()

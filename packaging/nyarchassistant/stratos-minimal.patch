+import json
+import os
+import tempfile
+import unittest
+
+from tests.gi_stubs import install
+
+install()
+
+from src.integrations.file_editing import FileEditingIntegration
+
+
+class FakeSettings:
+    def __init__(self, rules=None, main_path="/tmp"):
+        self.rules = rules
+        self.main_path = main_path
+
+    def get_string(self, key):
+        if key == "file-permissions":
+            if self.rules is None:
+                raise KeyError(key)
+            return json.dumps(self.rules)
+        if key == "path":
+            return self.main_path
+        return "{}"
+
+
+class FileEditingSafetyTests(unittest.TestCase):
+    def integration(self, rules=None):
+        if rules is None:
+            rules = [{"path": "*", "read": "allow", "write": "allow"}]
+        return FileEditingIntegration("", "", FakeSettings(rules))
+
+    def test_default_write_policy_requires_confirmation(self):
+        integration = FileEditingIntegration("", "", FakeSettings())
+        self.assertEqual(
+            integration._get_permission_mode("/tmp/example", "write"),
+            "ask",
+        )
+        with tempfile.TemporaryDirectory() as directory:
+            file_path = os.path.join(directory, "confirm.txt")
+            with open(file_path, "w", encoding="utf-8") as file:
+                file.write("data")
+            result = integration.delete_file(file_path)
+            self.assertTrue(result.requires_interaction)
+            self.assertTrue(os.path.exists(file_path))
+
+    def test_delete_removes_files_but_refuses_directories_and_directory_links(self):
+        integration = self.integration()
+        with tempfile.TemporaryDirectory() as directory:
+            file_path = os.path.join(directory, "file.txt")
+            with open(file_path, "w", encoding="utf-8") as file:
+                file.write("data")
+
+            output = integration.delete_file(file_path).get_output()
+            self.assertIn("Successfully deleted", output)
+            self.assertFalse(os.path.exists(file_path))
+
+            output = integration.delete_file(directory).get_output()
+            self.assertIn("Refusing to delete a directory", output)
+            self.assertTrue(os.path.isdir(directory))
+
+            target_directory = os.path.join(directory, "target")
+            os.mkdir(target_directory)
+            link_path = os.path.join(directory, "directory-link")
+            os.symlink(target_directory, link_path)
+            output = integration.delete_file(link_path).get_output()
+            self.assertIn("symlink to a directory", output)
+            self.assertTrue(os.path.lexists(link_path))
+
+    def test_move_refuses_overwrite_without_explicit_flag(self):
+        integration = self.integration()
+        with tempfile.TemporaryDirectory() as directory:
+            source = os.path.join(directory, "source.txt")
+            destination = os.path.join(directory, "destination.txt")
+            with open(source, "w", encoding="utf-8") as file:
+                file.write("source")
+            with open(destination, "w", encoding="utf-8") as file:
+                file.write("destination")
+
+            output = integration.move_file(source, destination).get_output()
+            self.assertIn("overwrite=true", output)
+            self.assertTrue(os.path.exists(source))
+
+            output = integration.move_file(
+                source,
+                destination,
+                overwrite=True,
+            ).get_output()
+            self.assertIn("Successfully moved", output)
+            self.assertFalse(os.path.exists(source))
+            with open(destination, encoding="utf-8") as file:
+                self.assertEqual(file.read(), "source")
+
+    def test_move_checks_destination_write_policy(self):
+        with tempfile.TemporaryDirectory() as directory:
+            source = os.path.join(directory, "source.txt")
+            destination = os.path.join(directory, "blocked.txt")
+            with open(source, "w", encoding="utf-8") as file:
+                file.write("source")
+            rules = [
+                {"path": "*", "read": "allow", "write": "allow"},
+                {"path": destination, "read": "allow", "write": "block"},
+            ]
+
+            output = self.integration(rules).move_file(source, destination).get_output()
+            self.assertIn("blocked", output)
+            self.assertTrue(os.path.exists(source))
+            self.assertFalse(os.path.exists(destination))
+
+    def test_operations_require_absolute_paths(self):
+        integration = self.integration()
+        self.assertIn(
+            "must be absolute",
+            integration.delete_file("relative.txt").get_output(),
+        )
+        self.assertIn(
+            "must be absolute",
+            integration.move_file("relative.txt", "/tmp/output").get_output(),
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()

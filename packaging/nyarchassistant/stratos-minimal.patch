+++ b/tests/gi_stubs.py
@@ -0,0 +1,147 @@
+"""Minimal GI import stubs for logic tests on headless systems."""
+
+import sys
+import types
+import builtins
+import gettext
+from pathlib import Path
+
+
+class _DummyValue:
+    def __call__(self, *_args, **_kwargs):
+        return self
+
+    def __getattr__(self, _name):
+        return self
+
+    def __or__(self, _other):
+        return self
+
+    def __and__(self, _other):
+        return self
+
+    def __iter__(self):
+        return iter(())
+
+    def __bool__(self):
+        return False
+
+
+_DUMMY = _DummyValue()
+
+
+class _DummyMeta(type):
+    def __getattr__(cls, _name):
+        return _DUMMY
+
+
+class _DummyWidget(metaclass=_DummyMeta):
+    def __init__(self, *_args, **_kwargs):
+        pass
+
+    def __getattr__(self, _name):
+        return _DUMMY
+
+
+class _RepositoryModule(types.ModuleType):
+    def __getattr__(self, name):
+        module = _GiModule(f"gi.repository.{name}")
+        sys.modules[module.__name__] = module
+        setattr(self, name, module)
+        return module
+
+
+class _GiModule(types.ModuleType):
+    def __getattr__(self, _name):
+        return _DummyWidget
+
+
+def install():
+    """Install stubs only when real GTK/Adwaita typelibs cannot be imported."""
+    if not hasattr(builtins, "_"):
+        builtins._ = gettext.gettext
+    try:
+        from gi.repository import Gtk, Adw  # noqa: F401
+        return
+    except (ImportError, ValueError):
+        pass
+
+    for name in list(sys.modules):
+        if name == "gi" or name.startswith("gi."):
+            del sys.modules[name]
+
+    gi = types.ModuleType("gi")
+    gi.require_version = lambda *_args: None
+    repository = _RepositoryModule("gi.repository")
+    gi.repository = repository
+    sys.modules["gi"] = gi
+    sys.modules["gi.repository"] = repository
+    for name in (
+        "Adw",
+        "Gdk",
+        "GdkPixbuf",
+        "Gio",
+        "GLib",
+        "GObject",
+        "Gtk",
+        "Pango",
+    ):
+        module = _GiModule(f"gi.repository.{name}")
+        setattr(repository, name, module)
+        sys.modules[module.__name__] = module
+
+    repo_root = Path(__file__).resolve().parents[1]
+
+    image_generator = types.ModuleType("src.handlers.image_generator")
+    image_generator.ImageGeneratorHandler = type("ImageGeneratorHandler", (), {})
+    sys.modules["src.handlers.image_generator"] = image_generator
+
+    ui_controller = types.ModuleType("src.ui_controller")
+    ui_controller.UIController = type("UIController", (), {})
+    sys.modules["src.ui_controller"] = ui_controller
+
+    extensions = types.ModuleType("src.extensions")
+
+    class NewelleExtension:
+        def __init__(self, pip_path, extension_path, settings):
+            self.pip_path = pip_path
+            self.path = pip_path
+            self.extension_path = extension_path
+            self.settings = settings
+            self.key = getattr(self, "id", "")
+
+    extensions.NewelleExtension = NewelleExtension
+    sys.modules["src.extensions"] = extensions
+
+    if "tiktoken" not in sys.modules:
+        tiktoken = types.ModuleType("tiktoken")
+        tiktoken.get_encoding = lambda *_args, **_kwargs: _DUMMY
+        tiktoken.encoding_for_model = lambda *_args, **_kwargs: _DUMMY
+        sys.modules["tiktoken"] = tiktoken
+
+    if "src.ui" not in sys.modules:
+        ui_package = types.ModuleType("src.ui")
+        ui_package.__path__ = [str(repo_root / "src" / "ui")]
+        sys.modules["src.ui"] = ui_package
+    widgets_package = types.ModuleType("src.ui.widgets")
+    widgets_package.__path__ = [str(repo_root / "src" / "ui" / "widgets")]
+    sys.modules["src.ui.widgets"] = widgets_package
+
+    widget_modules = {
+        "subagent": ("SubagentWidget",),
+        "scheduled_task": ("ScheduledTaskWidget",),
+        "question": ("QuestionWidget", "RestoredQuestionWidget"),
+        "comborow": ("ComboRowHelper",),
+        "file_read": ("ReadFileWidget",),
+        "file_edit": ("FileEditWidget",),
+        "file_permission_confirm": ("FilePermissionConfirmWidget",),
+        "glob": ("GlobWidget",),
+        "grep": ("GrepWidget",),
+        "list_directory": ("ListDirectoryWidget",),
+    }
+    for module_name, class_names in widget_modules.items():
+        full_name = f"src.ui.widgets.{module_name}"
+        module = types.ModuleType(full_name)
+        for class_name in class_names:
+            setattr(module, class_name, _DummyWidget)
+        sys.modules[full_name] = module

+                }
+                with patch.dict(os.environ, environment, clear=True):
+                    with patch("src.integrations.git_forge.urlopen", fake_urlopen):
+                        output = self.integration.list_issues(
+                            provider,
+                            "owner/repo",
+                            base_url=f"https://untrusted-{provider}.example",
+                        ).get_output()
+
+                self.assertIsNone(captured["request"].get_header(header))
+                self.assertFalse(
+                    may_attach_token(
+                        provider,
+                        f"https://untrusted-{provider}.example/issues",
+                        environment,
+                    )
+                )
+                self.assertNotIn(token, output)
+
+    def test_tokens_are_included_for_matching_configured_origins(self):
+        cases = (
+            (
+                "github",
+                "GITHUB_TOKEN",
+                "GITHUB_BASE_URL",
+                "https://github.internal:8443/api/v3",
+                "Authorization",
+                "Bearer secret-github",
+            ),
+            (
+                "gitlab",
+                "GITLAB_TOKEN",
+                "GITLAB_BASE_URL",
+                "https://gitlab.internal",
+                "Private-token",
+                "secret-gitlab",
+            ),
+            (
+                "gitea",
+                "GIT_FORGE_TOKEN",
+                "GIT_FORGE_BASE_URL",
+                "http://gitea.internal:3000",
+                "Authorization",
+                "token secret-gitea",
+            ),
+        )
+        for provider, token_name, base_name, base_url, header, expected in cases:
+            with self.subTest(provider=provider):
+                captured = {}
+
+                def fake_urlopen(request, timeout):
+                    captured["request"] = request
+                    return FakeResponse(b"[]")
+
+                token = expected.split(" ", 1)[-1]
+                with patch.dict(
+                    os.environ,
+                    {token_name: token, base_name: base_url},
+                    clear=True,
+                ):
+                    with patch("src.integrations.git_forge.urlopen", fake_urlopen):
+                        output = self.integration.list_issues(
+                            provider,
+                            "owner/repo",
+                        ).get_output()
+
+                self.assertEqual(captured["request"].get_header(header), expected)
+                self.assertNotIn(header, captured["request"].headers)
+                self.assertEqual(json.loads(output), [])
+                self.assertNotIn(token, output)
+
+    def test_token_is_redacted_from_http_errors(self):
+        token = "never-print-this-token"
+
+        def fake_urlopen(request, timeout):
+            raise RuntimeError(
+                f"request rejected with {request.get_header('Authorization')}"
+            )
+
+        with patch.dict(os.environ, {"GITHUB_TOKEN": token}, clear=True):
+            with patch("src.integrations.git_forge.urlopen", fake_urlopen):
+                output = self.integration.list_issues(
+                    "github",
+                    "owner/repo",
+                ).get_output()
+
+        self.assertIn("[REDACTED]", output)
+        self.assertNotIn(token, output)
+
+    def test_local_git_uses_argument_array_without_shell(self):
+        completed = subprocess.CompletedProcess([], 0, stdout=b"## main\n", stderr=b"")
+        with patch("src.integrations.git_forge.subprocess.run", return_value=completed) as run:
+            output = self.integration.git_status("/tmp").get_output()
+
+        self.assertEqual(output, "## main")
+        args, kwargs = run.call_args
+        self.assertEqual(
+            args[0],
+            [
+                "git",
+                "--no-optional-locks",
+                "-c",
+                "core.fsmonitor=false",
+                "-c",
+                "diff.external=",
+                "-C",
+                "/tmp",
+                "status",
+                "--short",
+                "--branch",
+            ],
+        )
+        self.assertNotIn("shell", kwargs)
+        self.assertEqual(kwargs["timeout"], 15)
+
+
+if __name__ == "__main__":
+    unittest.main()

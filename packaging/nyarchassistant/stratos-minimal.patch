new file mode 100644
index 0000000..2626c1e
--- /dev/null
+++ b/src/utility/compact.py
@@ -0,0 +1,52 @@
+"""Pure configuration helpers for the compact window layout."""
+
+from dataclasses import dataclass
+
+
+@dataclass(frozen=True)
+class WindowLayout:
+    width: int
+    height: int
+    chat_min_width: int
+    history_width: int
+    canvas_width: int
+    avatar_width: int
+    lazy_load_batch_size: int
+
+
+def _positive(value: int, fallback: int) -> int:
+    return value if isinstance(value, int) and value > 0 else fallback
+
+
+def resolve_window_layout(
+    compact_mode: bool,
+    window_width: int,
+    window_height: int,
+    compact_width: int,
+    compact_height: int,
+    compact_avatar_width: int,
+) -> WindowLayout:
+    """Resolve window and pane dimensions while preserving normal defaults."""
+    if not compact_mode:
+        return WindowLayout(
+            width=_positive(window_width, 1400),
+            height=_positive(window_height, 800),
+            chat_min_width=450,
+            history_width=300,
+            canvas_width=420,
+            avatar_width=400,
+            lazy_load_batch_size=10,
+        )
+
+    width = max(360, _positive(compact_width, 420))
+    height = max(480, _positive(compact_height, 720))
+    avatar_width = min(max(96, _positive(compact_avatar_width, 132)), width // 2)
+    return WindowLayout(
+        width=width,
+        height=height,
+        chat_min_width=max(240, width - avatar_width),
+        history_width=min(320, width - 40),
+        canvas_width=min(360, width - 24),
+        avatar_width=avatar_width,
+        lazy_load_batch_size=5,
+    )

+MAX_SWARM_TASKS = 32
+
+
+def enforce_swarm_cap(requested=DEFAULT_SWARM_CONCURRENCY, hard_cap=MAX_SWARM_CONCURRENCY) -> int:
+    """Return a safe worker count, bounded by the global maximum of eight."""
+    try:
+        safe_hard_cap = max(1, min(int(hard_cap), MAX_SWARM_CONCURRENCY))
+    except (TypeError, ValueError) as exc:
+        raise ValueError("hard_cap must be an integer") from exc
+    if requested is None:
+        return min(DEFAULT_SWARM_CONCURRENCY, safe_hard_cap)
+    try:
+        requested = int(requested)
+    except (TypeError, ValueError) as exc:
+        raise ValueError("concurrency must be an integer") from exc
+    if requested < 1:
+        raise ValueError("concurrency must be at least 1")
+    return min(requested, safe_hard_cap)
+
+
+def parse_swarm_tasks(tasks) -> list[dict[str, str]]:
+    """Normalize a JSON/list task specification without touching GTK."""
+    if isinstance(tasks, str):
+        try:
+            tasks = json.loads(tasks)
+        except json.JSONDecodeError as exc:
+            raise ValueError(f"tasks must be a valid JSON list: {exc.msg}") from exc
+    if not isinstance(tasks, list):
+        raise ValueError("tasks must be a list or a JSON-encoded list")
+    if not tasks:
+        raise ValueError("tasks must contain at least one task")
+    if len(tasks) > MAX_SWARM_TASKS:
+        raise ValueError(f"tasks may contain at most {MAX_SWARM_TASKS} entries")
+
+    normalized = []
+    for index, item in enumerate(tasks):
+        if isinstance(item, str):
+            item = {"task": item}
+        if not isinstance(item, dict):
+            raise ValueError(f"task {index + 1} must be a string or object")
+        task = item.get("task")
+        if not isinstance(task, str) or not task.strip():
+            raise ValueError(f"task {index + 1} must contain a non-empty 'task' string")
+        normalized_item = {"task": task.strip()}
+        for key in ("system_prompt", "tools", "skills"):
+            value = item.get(key, "")
+            if not isinstance(value, str):
+                raise ValueError(f"task {index + 1} field '{key}' must be a string")
+            normalized_item[key] = value
+        normalized.append(normalized_item)
+    return normalized
+
+
 

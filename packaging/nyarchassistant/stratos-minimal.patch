+from src.handlers.llm.ollama_catalog import get_recommended_ollama_models
+
+
+class OllamaCatalogTests(unittest.TestCase):
+    def test_catalog_has_installable_practical_small_models(self):
+        models = get_recommended_ollama_models()
+        small_models = [
+            model for model in models
+            if model["hardware_tier"] == "small"
+        ]
+
+        self.assertGreaterEqual(len(small_models), 2)
+        self.assertTrue(all(model["installable"] for model in models))
+        self.assertTrue(all("key" in model and "description" in model for model in models))

+import builtins
+import importlib.util
+import sys
+import types
+import unittest
+from unittest.mock import patch
+
+from tests.gi_stubs import install
+
+install()
+
+if importlib.util.find_spec("pydub") is None:
+    pydub = types.ModuleType("pydub")
+    pydub.AudioSegment = type("AudioSegment", (), {})
+    sys.modules["pydub"] = pydub
+
+if importlib.util.find_spec("requests_toolbelt") is None:
+    requests_toolbelt = types.ModuleType("requests_toolbelt")
+    multipart = types.ModuleType("requests_toolbelt.multipart")
+    encoder = types.ModuleType("requests_toolbelt.multipart.encoder")
+    encoder.MultipartEncoder = type("MultipartEncoder", (), {})
+    sys.modules["requests_toolbelt"] = requests_toolbelt
+    sys.modules["requests_toolbelt.multipart"] = multipart
+    sys.modules["requests_toolbelt.multipart.encoder"] = encoder
+
+from src.handlers.tts.gtts_handler import FALLBACK_VOICES, gTTSHandler
+
+
+class FakeSettings:
+    def get_string(self, _key):
+        return "{}"
+
+
+class GTTSHandlerTests(unittest.TestCase):
+    def setUp(self):
+        self.handler = gTTSHandler(FakeSettings(), "/tmp")
+
+    def test_extra_settings_use_safe_voice_when_gtts_is_missing(self):
+        real_import = builtins.__import__
+
+        def import_without_gtts(name, *args, **kwargs):
+            if name == "gtts":
+                raise ModuleNotFoundError("No module named 'gtts'", name="gtts")
+            return real_import(name, *args, **kwargs)
+
+        with patch("builtins.__import__", side_effect=import_without_gtts):
+            setting = self.handler.get_extra_settings()[0]
+
+        self.assertEqual(setting["values"], FALLBACK_VOICES)
+        self.assertEqual(setting["default"], "en")
+
+    def test_get_voices_uses_installed_gtts_metadata(self):
+        gtts = types.ModuleType("gtts")
+        gtts.lang = types.SimpleNamespace(
+            tts_langs=lambda: {"en": "English", "fr": "French"}
+        )
+
+        with patch.dict(sys.modules, {"gtts": gtts}):
+            voices = self.handler.get_voices()
+
+        self.assertEqual(voices, (("English", "en"), ("French", "fr")))
+
+
+if __name__ == "__main__":
+    unittest.main()

new file mode 100644
index 0000000..9cc20ba
--- /dev/null
+++ b/src/utility/language_accent.py
@@ -0,0 +1,126 @@
+"""Small, dependency-free language and TTS voice resolver."""
+
+import re
+import unicodedata
+from collections.abc import Iterable
+
+
+_WORDS = {
+    "en": {
+        "a", "and", "are", "can", "do", "for", "from", "good", "hello", "how",
+        "i", "in", "is", "it", "morning", "my", "of", "please", "that", "the",
+        "this", "to", "was", "we", "what", "with", "you", "your",
+    },
+    "fr": {
+        "alors", "avec", "bonjour", "ce", "comment", "dans", "de", "des",
+        "du", "elle", "est", "et", "je", "la", "le", "les", "mais", "merci",
+        "nous", "pas", "pour", "que", "qui", "salut", "sont", "un", "une", "vous",
+    },
+    "es": {
+        "buenos", "como", "con", "de", "días", "el", "en", "es", "esta",
+        "gracias", "hola", "la", "las", "los", "para", "por", "que", "se",
+        "un", "una", "y",
+    },
+    "de": {
+        "aber", "auf", "das", "der", "die", "ein", "eine", "für", "guten",
+        "hallo", "ich", "ist", "mit", "morgen", "nicht", "sie", "und", "von",
+        "was", "wie", "wir", "zu",
+    },
+    "it": {
+        "buongiorno", "che", "ciao", "come", "con", "di", "e", "grazie", "il",
+        "in", "la", "le", "ma", "non", "per", "sono", "un", "una",
+    },
+}
+
+_DISTINCTIVE = {
+    "en": {"good", "hello", "please", "the", "this", "what", "with", "your"},
+    "fr": {"avec", "bonjour", "comment", "des", "est", "merci", "pour", "salut", "une", "vous"},
+    "es": {"buenos", "como", "días", "esta", "gracias", "hola", "las", "los", "una"},
+    "de": {"aber", "auf", "das", "der", "die", "für", "guten", "hallo", "ich", "morgen", "nicht", "und"},
+    "it": {"buongiorno", "ciao", "come", "grazie", "sono"},
+}
+
+_ACCENTS = {
+    "fr": set("àâçéèêëîïôùûüÿœæ"),
+    "es": set("áéíóúüñ¿¡"),
+    "de": set("äöüß"),
+    "it": set("àèéìíîòóùú"),
+}
+
+_VOICE_PREFERENCES = {
+    "en": ("en-gb", "en-us", "en"),
+    "fr": ("fr-fr", "fr"),
+    "es": ("es-es", "es-mx", "es-us", "es"),
+    "de": ("de-de", "de-at", "de-ch", "de"),
+    "it": ("it-it", "it"),
+}
+
+
+def detect_language(text: str) -> str | None:
+    """Return a likely ISO 639-1 language code, or ``None`` if uncertain."""
+    if not isinstance(text, str):
+        return None
+
+    normalized = unicodedata.normalize("NFC", text).casefold()
+    tokens = re.findall(r"[^\W\d_]+", normalized, flags=re.UNICODE)
+    if not tokens:
+        return None
+
+    scores = {}
+    for language, words in _WORDS.items():
+        score = sum(1 for token in tokens if token in words)
+        score += sum(2 for token in tokens if token in _DISTINCTIVE[language])
+        if language in _ACCENTS:
+            score += sum(2 for character in normalized if character in _ACCENTS[language])
+        scores[language] = score
+
+    # Apostrophe contractions provide useful French evidence without requiring
+    # an external language model.
+    scores["fr"] += 2 * len(re.findall(r"\b(?:c|d|j|l|n|qu|s|t)'", normalized))
+    scores["en"] += 2 * len(re.findall(r"\b(?:i|you|we|they|it|do|does|is|are|was|were)n't\b", normalized))
+
+    ranked = sorted(scores.items(), key=lambda item: item[1], reverse=True)
+    best_language, best_score = ranked[0]
+    second_score = ranked[1][1]
+    if best_score < 3:
+        return None
+    if best_score == second_score:
+        return None
+    return best_language
+
+
+def _voice_ids(voices: Iterable) -> tuple[str, ...]:
+    result = []
+    for voice in voices or ():
+        voice_id = voice[1] if isinstance(voice, (tuple, list)) and len(voice) > 1 else voice
+        if isinstance(voice_id, str) and voice_id:
+            result.append(voice_id)
+    return tuple(result)
+
+
+def _matches_locale(voice_id: str, locale: str) -> bool:
+    normalized = voice_id.casefold().replace("_", "-")
+    locale = locale.casefold()
+    return normalized == locale or normalized.startswith(locale + "-")
+
+
+def resolve_voice_for_text(text: str, voices: Iterable, configured_voice: str | None) -> str | None:
+    """Choose a voice matching *text* without changing the configured voice.
+
+    The configured voice wins when it already matches the detected language.
+    If detection is uncertain or no matching voice exists, it is returned
+    unchanged.
+    """
+    language = detect_language(text)
+    available = _voice_ids(voices)
+    if language is None or not available:
+        return configured_voice
+
+    if isinstance(configured_voice, str) and _matches_locale(configured_voice, language):
+        return configured_voice
+
+    for locale in _VOICE_PREFERENCES[language]:
+        for voice_id in available:
+            if _matches_locale(voice_id, locale):
+                return voice_id
+    return configured_voice
diff --git a/src/utility/lifecycle.py b/src/utility/lifecycle.py
new file mode 100644
index 0000000..66eb4e1
--- /dev/null
+++ b/src/utility/lifecycle.py
@@ -0,0 +1,23 @@
+"""Small lifecycle helpers that do not depend on GTK."""
+
+
+class LifecycleCleanupGuard:
+    """Allow one cleanup claim for each activated resource lifecycle."""
+
+    def __init__(self):
+        self._active_resources = []
+
+    def activate(self, resource):
+        """Mark *resource* active, retaining object-identity semantics."""
+        if resource is None:
+            return
+        if not any(active is resource for active in self._active_resources):
+            self._active_resources.append(resource)
+
+    def claim_cleanup(self, resource) -> bool:
+        """Return true once for an active resource, then mark it inactive."""
+        for index, active in enumerate(self._active_resources):
+            if active is resource:
+                self._active_resources.pop(index)
+                return True
+        return False

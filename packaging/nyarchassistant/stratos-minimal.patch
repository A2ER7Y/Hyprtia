@@ -0,0 +1,98 @@
+import unittest
+
+from src.utility.language_accent import detect_language, resolve_voice_for_text
+
+
+class LanguageDetectionTests(unittest.TestCase):
+    def test_detects_english(self):
+        self.assertEqual(
+            detect_language("Hello, how are you? Please tell me what this is."),
+            "en",
+        )
+
+    def test_detects_french_with_and_without_accents(self):
+        self.assertEqual(
+            detect_language("Bonjour, comment allez-vous aujourd'hui ?"),
+            "fr",
+        )
+        self.assertEqual(
+            detect_language("Je vous remercie pour cette information."),
+            "fr",
+        )
+
+    def test_detects_fallback_languages(self):
+        self.assertEqual(detect_language("Hola, gracias por esta información."), "es")
+        self.assertEqual(detect_language("Buenos días"), "es")
+        self.assertEqual(detect_language("Hallo, wie ist das für dich?"), "de")
+        self.assertEqual(detect_language("Guten Morgen"), "de")
+        self.assertEqual(detect_language("Buongiorno, come sono le cose?"), "it")
+        self.assertEqual(detect_language("Ciao!"), "it")
+
+    def test_uncertain_text_has_no_language(self):
+        self.assertIsNone(detect_language("42!"))
+        self.assertIsNone(detect_language("OK"))
+
+
+class VoiceResolutionTests(unittest.TestCase):
+    VOICES = (
+        ("Sonia", "en-GB-SoniaNeural"),
+        ("Ava", "en-US-AvaNeural"),
+        ("Denise", "fr-FR-DeniseNeural"),
+        ("Elvira", "es-ES-ElviraNeural"),
+    )
+
+    def test_selects_preferred_matching_voice(self):
+        self.assertEqual(
+            resolve_voice_for_text(
+                "Hello, please tell me what this is.",
+                self.VOICES,
+                "fr-FR-DeniseNeural",
+            ),
+            "en-GB-SoniaNeural",
+        )
+        self.assertEqual(
+            resolve_voice_for_text(
+                "Bonjour, je vous remercie pour cette information.",
+                self.VOICES,
+                "en-US-AvaNeural",
+            ),
+            "fr-FR-DeniseNeural",
+        )
+
+    def test_retains_matching_configured_voice(self):
+        self.assertEqual(
+            resolve_voice_for_text(
+                "Hello, how are you today?",
+                self.VOICES,
+                "en-US-AvaNeural",
+            ),
+            "en-US-AvaNeural",
+        )
+
+    def test_supports_language_only_voice_ids(self):
+        self.assertEqual(
+            resolve_voice_for_text(
+                "Bonjour, merci pour votre réponse.",
+                (("English", "en"), ("Français", "fr")),
+                "en",
+            ),
+            "fr",
+        )
+
+    def test_retains_configured_voice_when_no_match_exists(self):
+        self.assertEqual(
+            resolve_voice_for_text(
+                "Guten Tag, wie ist das für dich?",
+                self.VOICES,
+                "en-US-AvaNeural",
+            ),
+            "en-US-AvaNeural",
+        )
+        self.assertEqual(
+            resolve_voice_for_text("OK", self.VOICES, "en-US-AvaNeural"),
+            "en-US-AvaNeural",
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()

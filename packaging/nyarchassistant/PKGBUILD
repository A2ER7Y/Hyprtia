# Maintainer: StratOS <https://github.com/A2ER7Y/Hyprtia>

pkgname=hyprtia-assistant
pkgver=1.4.5.stratos1
pkgrel=1
pkgdesc="Compact NyarchAssistant companion for Hyprtia and StratOS"
arch=('any')
url="https://github.com/NyarchLinux/NyarchAssistant"
license=('GPL-3.0-only')
depends=(
  'ffmpeg'
  'git'
  'gtksourceview5'
  'libadwaita'
  'python'
  'python-beautifulsoup4'
  'python-cairo'
  'python-edge-tts'
  'python-expandvars'
  'python-gobject'
  'python-hatch-fancy-pypi-readme'
  'python-hatchling'
  'python-livepng'
  'python-lxml'
  'python-lxml-html-clean'
  'python-markdownify'
  'python-matplotlib'
  'python-mcp'
  'python-newspaper'
  'python-openai'
  'python-pillow'
  'python-pyaudio'
  'python-pydub'
  'python-pylatexenc'
  'python-requests'
  'python-tiktoken'
  'vte4'
  'webkitgtk-6.0'
)
optdepends=(
  'ollama: native offline model server'
  'python-ollama: Ollama model management'
  'python-gtts: automatic language-aware Google TTS'
  'python-speechrecognition: speech recognition support'
)
makedepends=('git' 'meson')
provides=('nyarchassistant')
conflicts=('nyarchassistant-git')
_commit='bd632c7148d54f7d7cb8a9290862c99e9f66e61e'
source=(
  "NyarchAssistant::git+https://github.com/NyarchLinux/NyarchAssistant.git#commit=${_commit}"
  'stratos-minimal.patch'
)
sha256sums=(
  'SKIP'
  'd93b5a9d1de1383b4665bee9bf3334a3e7596cb95bb05eef271b40ba68663a72'
)

prepare() {
  git -C "$srcdir/NyarchAssistant" apply "$srcdir/stratos-minimal.patch"
}

build() {
  arch-meson "$srcdir/NyarchAssistant" build
  meson compile -C build
}

check() {
  cd "$srcdir/NyarchAssistant"
  PYTHONDONTWRITEBYTECODE=1 python -m unittest discover \
    -s tests -p 'test_*.py'
  glib-compile-schemas --strict --dry-run data
}

package() {
  meson install -C build --destdir "$pkgdir"
  chmod 755 "$pkgdir/usr/bin/nyarchassistant"
  install -Dm644 "$srcdir/NyarchAssistant/README.md" \
    "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 "$srcdir/NyarchAssistant/COPYING" \
    "$pkgdir/usr/share/licenses/$pkgname/COPYING"
}

#!/bin/sh

# Brain_Shell uses hyprshutdown for graceful session exits and hyprlock for
# lock/unlock transitions. Keep that integration behind one stable Hyprtia
# command so the session panel does not depend on user shell configuration.

set -eu

action=${1:-}
binary_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
prefix=$(dirname -- "$binary_dir")
strat_runner=$binary_dir/hyprtia-strat
lock_config=${HYPRTIA_LOCK_CONFIG:-"$prefix/share/hyprtia/brain-shell-hyprlock.conf"}

has_system() {
  if [ -x "$strat_runner" ]; then
    "$strat_runner" --check system "$1"
  else
    command -v "$1" >/dev/null 2>&1
  fi
}

run_system() {
  if [ -x "$strat_runner" ]; then
    exec "$strat_runner" system "$@"
  fi
  exec "$@"
}

case "$action" in
  lock)
    if has_system hyprlock; then
      run_system hyprlock -c "$lock_config"
    fi
    run_system loginctl lock-session
    ;;
  logout)
    if has_system hyprshutdown; then
      run_system hyprshutdown --top-label "Logging out..."
    fi
    run_system hyprctl dispatch exit
    ;;
  reboot)
    if has_system hyprshutdown; then
      run_system hyprshutdown --top-label "Restarting..." --post-cmd "systemctl reboot"
    fi
    run_system systemctl reboot
    ;;
  shutdown)
    if has_system hyprshutdown; then
      run_system hyprshutdown --top-label "Shutting down..." --post-cmd "systemctl poweroff"
    fi
    run_system systemctl poweroff
    ;;
  *)
    printf 'usage: %s {lock|logout|reboot|shutdown}\n' "${0##*/}" >&2
    exit 64
    ;;
esac

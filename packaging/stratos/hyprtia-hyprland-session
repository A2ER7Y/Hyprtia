#!/bin/sh

set -eu

binary_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
strat_runner=$binary_dir/hyprtia-strat
config_root=${HYPRTIA_HYPR_CONFIG_HOME:-${XDG_CONFIG_HOME:-"$HOME/.config"}}
config_dir=${config_root%/}/hypr
rule_file=$config_dir/hyprtia-confined-floats.conf

run_system() {
  if [ -x "$strat_runner" ]; then
    "$strat_runner" system "$@"
  else
    "$@"
  fi
}

if [ -x "$strat_runner" ]; then
  "$strat_runner" --check system hyprpm || exit 0
  "$strat_runner" --check system hyprctl || exit 0
else
  command -v hyprpm >/dev/null 2>&1 || exit 0
  command -v hyprctl >/dev/null 2>&1 || exit 0
fi
run_system hyprpm reload

if run_system hyprctl dispatch 'hl.dsp.no_op()' 2>/dev/null | grep -qx 'ok'; then
  # Re-evaluate the guarded Lua rule now that the plugin is loaded.
  run_system hyprctl reload
elif [ -f "$rule_file" ]; then
  # Hyprlang cannot guard an unknown plugin effect, so source it only now.
  run_system hyprctl keyword source "$rule_file"
fi

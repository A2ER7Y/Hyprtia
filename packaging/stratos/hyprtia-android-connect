#!/bin/sh

# The linked AndroidConnect plugin targets Noctalia's legacy Quickshell/QML
# runtime. Hyprtia v5 is native, so prefer that plugin's IPC when a compatible
# Quickshell instance is already running, then fall back to KDE Connect.

set -eu

binary_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
strat_runner=$binary_dir/hyprtia-strat
plugin_dir=${HYPRTIA_ANDROID_CONNECT_PLUGIN_DIR:-"${XDG_CONFIG_HOME:-"$HOME/.config"}/noctalia/plugins/androidconnect"}

has_app() {
  if [ -x "$strat_runner" ]; then
    "$strat_runner" --check apps "$1"
  else
    command -v "$1" >/dev/null 2>&1
  fi
}

run_app() {
  if [ -x "$strat_runner" ]; then
    "$strat_runner" apps "$@"
  else
    "$@"
  fi
}

exec_app() {
  if [ -x "$strat_runner" ]; then
    exec "$strat_runner" apps "$@"
  fi
  exec "$@"
}

if has_app qs && [ -f "$plugin_dir/manifest.json" ]; then
  if run_app qs ipc call plugin:androidconnect toggle >/dev/null 2>&1; then
    exit 0
  fi
fi

if has_app kdeconnect-app; then
  exec_app kdeconnect-app
fi

if has_app kdeconnect-settings; then
  exec_app kdeconnect-settings
fi

if has_app kdeconnect-cli; then
  exec_app kdeconnect-cli --list-devices
fi

if has_app notify-send; then
  run_app notify-send -a Hyprtia "Android Connect" \
    "Install KDE Connect, or install the AndroidConnect plugin in $plugin_dir"
fi
printf '%s\n' "Android Connect is unavailable: install KDE Connect or the AndroidConnect plugin." >&2
exit 127
